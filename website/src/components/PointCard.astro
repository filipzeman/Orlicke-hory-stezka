---
import Icon from "./Icon.astro";
import { getPointIcons } from "../utils/iconMapping";
import DetailedInfo from "./DetailedInfo.astro";
import { ETAPE_LENGTH } from "../constants/constants.ts";
import { slugify } from "../utils/slugify.ts";

const { filter, point, last } = Astro.props;

const icons = getPointIcons(point);

if (!icons.length) {
  return null;
}

const pointTypeIcon: string = icons.shift() || "";

const distanceToEtapeFinish: number = Math.max(0, ETAPE_LENGTH - point.km);

// slug (grouped vs standalone)
const slug = point.location_id ? point.location_id : slugify(point.point_name);

// navigation mode
const isNavigation = filter === "navigace";

// map Czech colors → UI colors
function getColor(color: string) {
  switch (color?.toLowerCase()) {
    case "červená":
      return "#c53030";
    case "modrá":
      return "#2c5282";
    case "zelená":
      return "#276749";
    case "žlutá":
      return "#b7791f";
    default:
      return "#ddd";
  }
}

// line color (only for navigation)
const lineColor =
  isNavigation && point.navigation_color ? getColor(point.navigation_color) : "#747474";
---

<div
  class={`item ${isNavigation ? "navigation" : ""} ${last ? "last" : ""}`}
  style={`--line-color: ${lineColor}`}
>
  <!-- KM -->
  <div class="km">
    <span>{point.km}</span>
  </div>

  <!-- CONTENT -->
  <div class={!filter || filter == "all" ? "content default" : "content"}>
    <a href={`/bod/${slug}`} class="name">
      {point.point_name}
      <Icon name={pointTypeIcon} size={18} notInteractive />
    </a>

    {
      filter === "ubytovani" || filter === "obcerstveni" ? (
        <DetailedInfo point={point} />
      ) : (
        <div class="icons">
          {icons.map((icon) => (
            <Icon name={icon} notInteractive />
          ))}
        </div>
      )
    }
  </div>
</div>

<style>
  .item {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 1rem;
    position: relative;
    align-content: center;
  }

  /* DOT (anchor point) */
  .item::before {
    position: absolute;
    content: "";
    left: -2px;
    top: 0.9rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: white;
    border: 2px solid black;
    z-index: 2;
  }

  /* LINE SEGMENT */
  .item::after {
    content: "";
    position: absolute;
    left: 4px;
    top: 1.1rem;
    bottom: -1rem;
    width: 2px;
    background: var(--line-color, #747474);
    z-index: 1;
  }

  /* last item → no segment */
  .item.last::after {
    display: none;
  }

  /* navigation mode → colored dot
.item.navigation::before {
  background: var(--line-color);
  border-color: var(--line-color);
} */

  /* KM */
  .km {
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-primary);
    text-align: right;
    padding-left: 1rem;
    padding-top: 0.4rem;
  }

  /* CONTENT */
  .content {
    display: flex;
    flex-direction: column;
    padding: 0.4rem 0;
  }

  /* NAME */
  .name {
    font-weight: 600;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  /* ICONS */
  .icons {
    display: flex;
    gap: 0.4rem;
  }

  /* optional */
  .small {
    font-size: 0.75rem;
    opacity: 0.6;
  }
</style>
