---
import Icon from "../Icon.astro";

const { service } = Astro.props;
---

<div class="card">
  <div class="title">{service.point_name}</div>

  {
    service.phone && (
      <a href={`tel:${service.phone}`}>
        <Icon name="Phone" size={16} notInteractive />
        {service.phone}
      </a>
    )
  }

  {
    service.website && (
      <a href={service.website} target="_blank">
        <Icon name="Globe" size={16} notInteractive />
        Web
      </a>
    )
  }

  {
    service.opening_info && (
      <div>
        <Icon name="Clock" size={16} notInteractive />
        {service.opening_info}
      </div>
    )
  }

  {service.note && <div class="note">{service.note}</div>}
</div>

<style>
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    font-size: 0.95rem;
    border-radius: 10px;
  }

  .title {
    font-weight: 600;
    margin-bottom: 4px;
  }

  .note {
    margin-top: 6px;
    font-size: 0.85rem;
    color: #555;
  }
</style>
