---
import Icon from "./Icon.astro";
import { FIRST_LEVEL_NAVIGATION } from "../constants/constants";
import { createNavItems } from "../utils/slugify";

const currentPath = Astro.url.pathname;
const firstLevelNavigationItems = createNavItems(FIRST_LEVEL_NAVIGATION);
---

<header class="header">
  <div class="inner">
    <div class="header-actions">
      <a href="/" class="logo">Na Stezce Českem</a>

      <button class="menu-toggle" aria-expanded="false" aria-controls="nav">
        <Icon name="SquareMenu" noBackground size={26} />
        <span class="sr-only">Menu</span>
      </button>
    </div>

    <nav id="nav" class="nav">
      {
        firstLevelNavigationItems.map((item) => (
          <a href={`/${item.slug}`} class={currentPath === `/${item.slug}` ? "active" : ""}>
            {item.name}
          </a>
        ))
      }
    </nav>
  </div>
  <script>
    const toggle = document.querySelector(".menu-toggle");
    const nav = document.querySelector(".nav");

    toggle?.addEventListener("click", () => {
      const isOpen = nav?.classList.toggle("open");
      toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
    });
  </script>

  <style>
    .header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: white;
      border-bottom: 1px solid #eee;
      /* justify-content: center;
      display: flex; */
    }

    .inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: space-between;
      padding: 0.7rem 1.5rem;
      max-width: var(--max-width);

      @media (min-width: 768px) {
        padding: 20px 1rem;
        flex-direction: row;
        margin: 0 auto;
        height: 66px;
      }
    }

    .header-actions {
      display: flex;
      width: 100%;
      justify-content: space-between;
      align-items: center;

      @media (min-width: 768px) {
        width: auto;
      }
    }

    .logo {
      font-weight: 600;
      text-decoration: none;
      color: inherit;
      white-space: nowrap;
    }

    .menu-toggle {
      background: none;
      border: none;
      display: flex;
      font-size: 1.2rem;
      cursor: pointer;
      width: 42px;
      height: 42px;

      svg {
        stroke: black;
      }
    }

    /* Mobile nav */
    .nav {
      display: none;
      flex-direction: column;
      background: white;
    }

    .nav a {
      padding: 0.6rem 0;
      text-decoration: none;
      color: var(--color-text);
      border-bottom: 1px solid #f0f0f0;

      &:last-of-type {
        border-bottom: none;
      }
    }

    .nav a.active {
      color: var(--color-primary);
      font-weight: 600;
    }

    .nav.open {
      display: flex;
      width: 100%;

      @media (min-width: 768px) {
        justify-content: flex-end;
      }
    }

    /* Desktop */
    @media (min-width: 768px) {
      .menu-toggle {
        display: none;
      }

      .nav {
        display: flex !important;
        flex-direction: row;
        gap: 1.5rem;
        padding: 0;
      }

      .nav a {
        border: none;
        padding: 0;
      }
    }

    /* Accessibility helper */
    .sr-only {
      position: absolute;
      left: -9999px;
    }
  </style>
</header>
