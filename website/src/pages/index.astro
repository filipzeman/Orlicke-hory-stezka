---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
---

<BaseLayout title="Stezka Orlické hory">
  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="hero-bg"></div>

      <div class="hero-content container">
        <h1>Stezka Orlické hory</h1>

        <p class="subtitle">
          Přehled bodů, služeb a zajímavostí podél trasy. Naplánuj si přechod jednoduše a přehledně.
        </p>

        <a href="/itinerar" class="cta"> Zobrazit itinerář</a>
      </div>
    </section>

    <!-- WHAT -->
    <section class="container section">
      <h2><Icon name="Map" size={20} noBackground /> Co zde najdeš</h2>

      <div class="grid">
        <div class="item">
          <Icon name="Mountain" size={20} />
          <span>Body podél trasy (km)</span>
        </div>

        <div class="item">
          <Icon name="Bed" size={20} />
          <span>Ubytování</span>
        </div>

        <div class="item">
          <Icon name="Utensils" size={20} />
          <span>Občerstvení</span>
        </div>

        <div class="item">
          <Icon name="Droplet" size={20} />
          <span>Voda</span>
        </div>

        <div class="item">
          <Icon name="BusFront" size={20} />
          <span>Doprava</span>
        </div>

        <div class="item">
          <Icon name="Signpost" size={20} />
          <span>Navigace</span>
        </div>
      </div>
    </section>

    <!-- HOW -->
    <section class="container section">
      <h2><Icon name="Route" size={20} noBackground /> Jak to použít</h2>

      <div class="steps">
        <div class="step">
          <span class="number">1</span>
          <p>Otevři itinerář</p>
        </div>

        <div class="step">
          <span class="number">2</span>
          <p>Procházej body podle kilometrů</p>
        </div>

        <div class="step">
          <span class="number">3</span>
          <p>Filtruj (ubytování, voda…)</p>
        </div>

        <div class="step">
          <span class="number">4</span>
          <p>Klikni na detail bodu</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="container section center">
      <h2>Připraven vyrazit?</h2>

      <a href="/itinerar" class="cta large"> Zobrazit itinerář</a>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    position: relative;
    height: 50vh;
    min-height: 420px;

    display: flex;
    align-items: center;
    justify-content: center;

    overflow: hidden;
  }

  /* background image */
  .hero-bg {
    position: absolute;
    inset: 0;

    background-image: url("/images/hero.jpg");
    background-size: cover;
    background-position: center;
    animation: zoom 20s ease-in-out infinite alternate;

    z-index: 1;
  }

  /* overlay */
  .hero-bg::after {
    content: "";
    position: absolute;
    inset: 0;

    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.55));
  }

  @keyframes zoom {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.05);
    }
  }

  /* content */
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: white;

    max-width: 600px;
  }

  /* typography */
  .hero h1 {
    font-size: 2.3rem;
    margin-bottom: 12px;
  }

  .subtitle {
    margin-bottom: 20px;
    opacity: 0.9;
  }

  /* CTA */
  .cta {
    display: inline-block;
    padding: 12px 18px;

    border-radius: 10px;
    background: var(--color-primary);

    color: white;
    text-decoration: none;
    font-weight: 600;
  }

  /* mobile tweak */
  @media (max-width: 600px) {
    .hero {
      height: 50vh;
    }

    .hero h1 {
      font-size: 1.8rem;
    }
  }

  /* SECTIONS */
  .section {
    margin-top: 24px;
  }

  /* GRID */
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 12px;
  }

  .item {
    display: flex;
    align-items: center;
    gap: 8px;

    padding: 10px;
    border-radius: 10px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  /* STEPS */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 12px;
  }

  .step {
    display: flex;
    align-items: center;
    gap: 10px;

    padding: 10px;
    border-radius: 10px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .number {
    width: 24px;
    height: 24px;

    display: flex;
    align-items: center;
    justify-content: center;

    border-radius: 50%;
    background: var(--color-primary);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
  }

  /* CENTER */
  .center {
    text-align: center;
  }
</style>
