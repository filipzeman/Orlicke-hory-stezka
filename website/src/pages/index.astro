---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
---

<BaseLayout title="Stezka Orlické hory">
  <main>
    <!-- HERO -->
    <section class="hero container">
      <h1>Stezka Orlické hory</h1>

      <p class="subtitle">
        Přehled bodů, služeb a zajímavostí podél trasy. Naplánuj si přechod jednoduše a přehledně.
      </p>

      <a href="/itinerar" class="cta"> Zobrazit itinerář</a>
    </section>

    <!-- WHAT -->
    <section class="container section">
      <h2>🧭 Co zde najdeš</h2>

      <div class="grid">
        <div class="item">
          <Icon name="Mountain" size={20} />
          <span>Body podél trasy (km)</span>
        </div>

        <div class="item">
          <Icon name="Bed" size={20} />
          <span>Ubytování</span>
        </div>

        <div class="item">
          <Icon name="Utensils" size={20} />
          <span>Občerstvení</span>
        </div>

        <div class="item">
          <Icon name="Droplet" size={20} />
          <span>Voda</span>
        </div>

        <div class="item">
          <Icon name="BusFront" size={20} />
          <span>Doprava</span>
        </div>

        <div class="item">
          <Icon name="Signpost" size={20} />
          <span>Navigace</span>
        </div>
      </div>
    </section>

    <!-- HOW -->
    <section class="container section">
      <h2>🥾 Jak to použít</h2>

      <div class="steps">
        <div class="step">
          <span class="number">1</span>
          <p>Otevři itinerář</p>
        </div>

        <div class="step">
          <span class="number">2</span>
          <p>Procházej body podle kilometrů</p>
        </div>

        <div class="step">
          <span class="number">3</span>
          <p>Filtruj (ubytování, voda…)</p>
        </div>

        <div class="step">
          <span class="number">4</span>
          <p>Klikni na detail bodu</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="container section center">
      <h2>Připraven vyrazit?</h2>

      <a href="/itinerar" class="cta large"> Zobrazit itinerář</a>
    </section>
  </main>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    text-align: center;
    padding-top: 40px;
    padding-bottom: 40px;
  }

  .hero h1 {
    font-size: 2rem;
    margin-bottom: 12px;
  }

  .subtitle {
    color: var(--color-text-muted);
    margin-bottom: 20px;
  }

  /* CTA */
  .cta {
    display: inline-block;
    padding: 12px 18px;
    border-radius: 10px;
    background: var(--color-primary);
    color: white;
    text-decoration: none;
    font-weight: 600;
  }

  .cta.large {
    padding: 14px 22px;
    font-size: 1.1rem;
  }

  /* SECTIONS */
  .section {
    margin-top: 32px;
  }

  /* GRID */
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 12px;
  }

  .item {
    display: flex;
    align-items: center;
    gap: 8px;

    padding: 10px;
    border-radius: 10px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  /* STEPS */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 12px;
  }

  .step {
    display: flex;
    align-items: center;
    gap: 10px;

    padding: 10px;
    border-radius: 10px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .number {
    width: 24px;
    height: 24px;

    display: flex;
    align-items: center;
    justify-content: center;

    border-radius: 50%;
    background: var(--color-primary);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
  }

  /* CENTER */
  .center {
    text-align: center;
  }
</style>
