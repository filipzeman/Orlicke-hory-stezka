---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSupabase } from "../lib/supabase";

const supabase = getSupabase();

const { data: points } = await supabase.from("points").select("id, point_name").order("point_name");

const { data: images } = await supabase
  .from("images")
  .select("id, url, point_id")
  .order("id", { ascending: false });

const pointMap = Object.fromEntries((points ?? []).map((p) => [p.id, p.point_name]));
---

<BaseLayout title="Admin">
  <main class="admin">
    <!-- LOGIN -->
    <div id="login" class="card hidden">
      <h2>Přihlášení</h2>

      <input id="email" type="email" placeholder="Email" />
      <input id="password" type="password" placeholder="Heslo" />

      <button id="login-btn">Přihlásit</button>
      <p id="error" class="error"></p>
    </div>

    <!-- DASHBOARD -->
    <div id="dashboard" class="hidden">
      <h1>Admin</h1>

      <!-- UPLOAD -->
      <div class="card">
        <h3>Nahrát obrázky</h3>

        <form id="upload-form" class="form">
          <select name="point_id" required>
            <option value="">-- Vyber bod --</option>
            {points?.map((p) => <option value={p.id}>{p.point_name}</option>)}
          </select>

          <input
            type="file"
            name="files"
            multiple
            accept="image/jpeg,image/png,image/webp"
            required
          />

          <button type="submit">Nahrát</button>
        </form>
      </div>

      <!-- GALLERY -->
      <div class="card">
        <h3>Nahrané obrázky</h3>

        <div class="gallery">
          {
            images?.map((img) => (
              <div class="image-item">
                <img src={img.url} loading="lazy" />
                <div class="meta">{pointMap[img.point_id] || "Neznámý bod"}</div>
              </div>
            ))
          }
        </div>
      </div>

      <button id="logout-btn" class="logout">Odhlásit</button>
    </div>
  </main>

  <!-- ENV -->
  <script>
    window.ENV = {
      SUPABASE_URL: import.meta.env.PUBLIC_SUPABASE_URL,
      SUPABASE_KEY: import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    };
  </script>

  <!-- CLIENT -->
  <script type="module">
    import { createClient } from "https://esm.sh/@supabase/supabase-js";

    document.addEventListener("DOMContentLoaded", async () => {
      const supabase = createClient(window.ENV.SUPABASE_URL, window.ENV.SUPABASE_KEY);

      const loginEl = document.getElementById("login");
      const dashboardEl = document.getElementById("dashboard");

      const emailEl = document.getElementById("email");
      const passwordEl = document.getElementById("password");
      const loginBtn = document.getElementById("login-btn");
      const logoutBtn = document.getElementById("logout-btn");
      const errorEl = document.getElementById("error");

      const form = document.getElementById("upload-form");

      // 🔹 session
      const {
        data: { session },
      } = await supabase.auth.getSession();

      if (session) showDashboard();
      else showLogin();

      // 🔹 login
      loginBtn?.addEventListener("click", async () => {
        errorEl.textContent = "";

        const { error } = await supabase.auth.signInWithPassword({
          email: emailEl.value,
          password: passwordEl.value,
        });

        if (error) errorEl.textContent = error.message;
        else showDashboard();
      });

      // 🔹 logout
      logoutBtn?.addEventListener("click", async () => {
        await supabase.auth.signOut();
        showLogin();
      });

      // 🔥 FIXED UPLOAD HANDLER
      if (form) {
        form.addEventListener("submit", async (e) => {
          e.preventDefault();

          const formData = new FormData(form);

          const res = await fetch("/api/upload", {
            method: "POST",
            body: formData,
          });

          if (res.ok) {
            alert("✅ Obrázky nahrány");
            window.location.reload();
          } else {
            alert("❌ Upload selhal");
          }
        });
      } else {
        console.error("❌ upload-form not found");
      }

      function showLogin() {
        loginEl.classList.remove("hidden");
        dashboardEl.classList.add("hidden");
      }

      function showDashboard() {
        loginEl.classList.add("hidden");
        dashboardEl.classList.remove("hidden");
      }
    });
  </script>
</BaseLayout>

<style>
  .admin {
    max-width: 500px;
    margin: 0 auto;
    padding: 16px;
  }

  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 16px;
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  input,
  select {
    padding: 12px;
    border-radius: 8px;
    border: 1px solid var(--color-border);
  }

  button {
    padding: 12px;
    border-radius: 8px;
    border: none;
    background: var(--color-primary);
    color: white;
    font-weight: 600;
  }

  .logout {
    width: 100%;
    background: #e53e3e;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }

  @media (min-width: 600px) {
    .gallery {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .image-item img {
    width: 100%;
    height: 120px;
    object-fit: cover;
    border-radius: 8px;
  }

  .meta {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .hidden {
    display: none;
  }

  .error {
    color: #c53030;
  }
</style>
