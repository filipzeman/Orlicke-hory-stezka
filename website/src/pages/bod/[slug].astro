---
import { supabase } from "../../lib/supabase";
import BaseLayout from "../../layouts/BaseLayout.astro";
import DetailHeader from "../../components/detail/DetailHeader.astro";
import DetailSummary from "../../components/detail/DetailSummary.astro";
import DetailSection from "../../components/detail/DetailSection.astro";
import ServiceCard from "../../components/detail/ServiceCard.astro";

import { categoryMap, typeMap } from "../../utils/dataMapping";
import { slugify } from "../../utils/slugify";

// 1. get slug from URL
const { slug } = Astro.params;

// 2. fetch ALL points (simple & fast enough)
const { data } = await supabase.from("points").select("*");

const points = data ?? [];

// 3. normalize (map Czech → keys)
function mapKey(map: Record<string, string>, value: string | null | undefined) {
  if (!value) return null;
  return map[value] ?? null;
}

const normalized = points.map((p) => ({
  ...p,
  categoryKey: mapKey(categoryMap, p.category),
  typeKey: mapKey(typeMap, p.type),
}));

const normalize = (v: string | undefined) => v?.toLowerCase().replace(/_/g, "-");

const locationPoints = normalized.filter((p) => {
  // grouped
  if (p.location_id) {
    return normalize(p.location_id) === normalize(slug);
  }

  // standalone (match slugified name)
  return slugify(p.point_name) === slug;
});

// 5. get location info
const location = locationPoints[0] ?? null;

// 6. group by category
const grouped: Record<string, typeof locationPoints> = {
  ubytovani: locationPoints.filter((p) => p.categoryKey === "ubytovani"),
  obcerstveni: locationPoints.filter((p) => p.categoryKey === "obcerstveni"),
  doprava: locationPoints.filter((p) => p.categoryKey === "doprava"),
  navigace: locationPoints.filter((p) => p.categoryKey === "navigace"),
  turisticke_cile: locationPoints.filter((p) => p.categoryKey === "turisticke_cile"),
  ostatni: locationPoints.filter((p) => p.categoryKey === "ostatni"),
};

// 7. order of sections
const sections = [
  { key: "ubytovani", title: "Ubytování" },
  { key: "obcerstveni", title: "Občerstvení" },
  { key: "navigace", title: "Navigace" },
  { key: "doprava", title: "Dopra" },
  { key: "turisticke_cile", title: "Turistické cíle" },
  { key: "ostatni", title: "Ostatní" },
];

console.log("sections", sections);
console.log("grouped", grouped);
---

<BaseLayout title={`${location?.location_name || location?.point_name} | Orlické hory`}>
  <main class="container">
    {
      location && (
        <>
          <DetailHeader location={location} services={locationPoints} />

          {sections.map(
            (section) =>
              grouped[section.key]?.length > 0 && (
                <DetailSection title={section.title}>
                  {grouped[section.key].map((service) => (
                    <ServiceCard service={service} />
                  ))}
                </DetailSection>
              )
          )}
        </>
      )
    }
  </main>
</BaseLayout>
