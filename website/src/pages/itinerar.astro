---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSupabase } from "../lib/supabase.ts";
import PointCard from "../components/PointCard.astro";
import Icon from "../components/Icon.astro";
import IconGuide from "../components/IconGuide.astro";

import { categoryMap, typeMap } from "../utils/dataMapping.ts";
import { mapKey } from "../utils/mapKey.ts";
import { groupPointsByLocation } from "../utils/groupPoints";
import type { Point } from "../types/point";

const supabase = getSupabase();
let { data, error } = await supabase.from("points").select("*").order("km", { ascending: true });

if (error) {
  console.error("Error fetching points:", error);
}

let points = data as Point[];

if (!points) {
  return null;
}

const groupedPoints = groupPointsByLocation(points);
groupedPoints.sort((a, b) => a.km - b.km);

const sortedPoints = points
  .map((p) => ({
    ...p,
    categoryKey: mapKey(categoryMap, p.category),
    typeKey: mapKey(typeMap, p.type),
  }))
  .sort((a, b) => a.km - b.km);

const filter = Astro.url.searchParams.get("filter");

console.log("ENV URL:", import.meta.env.PUBLIC_SUPABASE_URL);

const filteredPoints = sortedPoints.filter((point) => {
  if (!filter || filter === "vse") return true;
  if (filter === "ubytovani") return point.categoryKey == "ubytovani";
  if (filter === "obcerstveni") return point.categoryKey == "obcerstveni";
  if (filter === "navigace") return point.categoryKey == "navigace";
  if (filter === "doprava") return point.categoryKey == "doprava";
  if (filter === "turisticke_cile") return point.categoryKey == "turisticke_cile";
  if (filter === "ostatni") return point.categoryKey == "ostatni";
  return true;
});

const filters = [
  { key: "vse", label: "Vše" },
  { key: "ubytovani", label: "Ubytování", icon: "Bed" },
  { key: "obcerstveni", label: "Občerstvení", icon: "Utensils" },
  { key: "navigace", label: "Navigace", icon: "Signpost" },
  { key: "doprava", label: "Doprava", icon: "BusFront" },
  { key: "turisticke_cile", label: "Turistické cíle", icon: "Mountain" },
  { key: "ostatni", label: "Ostatní", icon: "Info" },
];
---

<BaseLayout title="Itinerář | Orlické hory">
  <section class="container">
    <h1>Itinerář</h1>
    <p class="subtitle">Přehled bodů podél trasy etapy Orlické hory.</p>
  </section>

  <section class="container">
    <!-- <IconGuide /> -->

    <div class="filters-wrapper">
      <div class="filters">
        {
          filters.map((f) => (
            <a
              href={`/itinerar?filter=${f.key}`}
              class={`filter ${(filter ?? "vse") === f.key ? "active" : ""}`}
            >
              {/* <Icon name={f.icon || "Info"} size={16} notInteractive /> */}
              <span>{f.label}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="container points">
    {
      filteredPoints.map((point, index) => (
        <PointCard filter={filter} point={point} last={index === filteredPoints.length - 1} />
      ))
    }
  </section>
</BaseLayout>

<style>
  .points {
    display: flex;
    flex-direction: column;
    padding-left: 20px;
    /* gap: 1rem; */
  }

  /* label */
  .filters-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 6px;
  }

  /* container */
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* button */
  .filter {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 6px;

    padding: 8px 12px;
    border-radius: 999px;

    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);

    text-decoration: none;
    font-size: 0.9rem;
    white-space: nowrap;
  }

  /* active */
  .filter.active {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  /* icon inside active */
  .filter.active svg {
    color: white !important;
    stroke: white !important;
    background-color: var(--color-primary) !important;
  }

  .subtitle {
    margin-bottom: 0;
  }
</style>
